# Server
PORT=3001

# OpenAI — keep on server, never expose to frontend
OPENAI_API_KEY=sk-...

# CORS — URL of the React PDP frontend
FRONTEND_URL=http://localhost:5174

# Shopify Admin API (used to fetch metaobjects server-side)
# Leave blank in dev; the backend falls back to hardcoded routine_template data
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_...
