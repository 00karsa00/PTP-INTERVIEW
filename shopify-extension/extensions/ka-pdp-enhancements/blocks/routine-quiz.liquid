{% comment %}
  App Block: Kerala Ayurveda — Routine Quiz & Recommendation
  Target:    main-product (works on any OS2 theme — Dawn, Refresh, Sense…)

  Merchant-editable via Theme Editor (block.settings):
    heading, subheading, api_endpoint, quiz_config_ref, show_disclaimer

  Product-specific via Shopify Admin metafield:
    custom.benefit_bullets  (List of single-line text)
{% endcomment %}

{{- 'routine-quiz.css' | asset_url | stylesheet_tag -}}

{%- comment -%} Step 1: resolve all settings and metaobject values {%- endcomment -%}

{%- assign product_benefits = product.metafields.custom.benefit_bullets.value -%}
{%- assign quiz_cfg = block.settings.quiz_config_ref -%}
{%- assign api_url = block.settings.api_endpoint | default: '' -%}

{%- comment -%} Question text — use metaobject if set, otherwise hardcoded defaults {%- endcomment -%}
{%- assign q1_text = 'What are you looking for?' -%}
{%- assign q2_text = 'How often do you plan to take it?' -%}
{%- if quiz_cfg != blank -%}
  {%- if quiz_cfg.question_1_text != blank -%}{%- assign q1_text = quiz_cfg.question_1_text -%}{%- endif -%}
  {%- if quiz_cfg.question_2_text != blank -%}{%- assign q2_text = quiz_cfg.question_2_text -%}{%- endif -%}
{%- endif -%}

{%- comment -%} Goal options — metaobject list, or comma-string, or built-in defaults {%- endcomment -%}
{%- assign default_goal_opts = 'Stress & calm,Energy & focus,Sleep quality' | split: ',' -%}
{%- assign default_freq_opts = 'Once daily,Twice daily' | split: ',' -%}

{%- assign goal_options = default_goal_opts -%}
{%- assign freq_options = default_freq_opts -%}

{%- if quiz_cfg != blank -%}
  {%- assign goal_opts_raw = quiz_cfg.question_1_options -%}
  {%- assign freq_opts_raw = quiz_cfg.question_2_options -%}

  {%- if goal_opts_raw != blank -%}
    {%- if goal_opts_raw.first -%}
      {%- assign goal_options = goal_opts_raw -%}
    {%- else -%}
      {%- assign goal_options = goal_opts_raw | split: ',' -%}
    {%- endif -%}
  {%- endif -%}

  {%- if freq_opts_raw != blank -%}
    {%- if freq_opts_raw.first -%}
      {%- assign freq_options = freq_opts_raw -%}
    {%- else -%}
      {%- assign freq_options = freq_opts_raw | split: ',' -%}
    {%- endif -%}
  {%- endif -%}
{%- endif -%}

<div
  class="ka-quiz-block"
  id="ka-quiz-{{ block.id }}"
  aria-labelledby="ka-quiz-heading-{{ block.id }}"
  data-api-url="{{ api_url | escape }}"
  data-block-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  <div class="ka-quiz__inner">

    {%- if block.settings.heading != blank -%}
      <h2 id="ka-quiz-heading-{{ block.id }}" class="ka-quiz__heading">
        {{- block.settings.heading | escape -}}
      </h2>
    {%- endif -%}

    {%- if block.settings.subheading != blank -%}
      <p class="ka-quiz__subheading">{{- block.settings.subheading | escape -}}</p>
    {%- endif -%}

    <div class="ka-quiz__progress" aria-hidden="true">
      <div class="ka-quiz__progress-fill" data-progress-fill></div>
    </div>

    {%- comment -%} Step 0 — Goal {%- endcomment -%}
    <div class="ka-quiz__step" data-step-panel="0">
      <p class="ka-quiz__question" id="ka-q1-{{ block.id }}">{{- q1_text | escape -}}</p>
      <div class="ka-quiz__options" role="group" aria-labelledby="ka-q1-{{ block.id }}">
        {%- for option in goal_options -%}
          {%- assign opt_text = option | strip -%}
          {%- assign goal_val = opt_text | downcase | replace: ' ', '_' | replace: '&', '' | replace: '__', '_' -%}
          <button type="button" class="ka-quiz__option" data-goal="{{ goal_val }}" aria-pressed="false">
            {{- opt_text | escape -}}
          </button>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Step 1 — Frequency {%- endcomment -%}
    <div class="ka-quiz__step ka-quiz__step--hidden" data-step-panel="1">
      <p class="ka-quiz__question" id="ka-q2-{{ block.id }}">{{- q2_text | escape -}}</p>
      <div class="ka-quiz__options" role="group" aria-labelledby="ka-q2-{{ block.id }}">
        {%- for option in freq_options -%}
          {%- assign opt_text = option | strip -%}
          {%- assign freq_val = opt_text | downcase | replace: ' ', '_' -%}
          <button type="button" class="ka-quiz__option" data-frequency="{{ freq_val }}" aria-pressed="false">
            {{- opt_text | escape -}}
          </button>
        {%- endfor -%}
      </div>

      <div class="ka-quiz__context-wrap">
        <label for="ka-context-{{ block.id }}" class="ka-quiz__context-label">
          Anything else? <span class="ka-quiz__context-optional">(optional)</span>
        </label>
        <textarea
          id="ka-context-{{ block.id }}"
          class="ka-quiz__context-input"
          placeholder="e.g. I travel frequently, or I prefer mornings…"
          rows="2"
          maxlength="200"
        ></textarea>
      </div>

      <div class="ka-quiz__nav">
        <button type="button" class="ka-quiz__back-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          Back
        </button>
        <button type="button" class="ka-quiz__submit-btn" disabled aria-disabled="true">
          Get my routine
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

    {%- comment -%} Step 2 — Result (JS renders content) {%- endcomment -%}
    <div class="ka-quiz__step ka-quiz__step--hidden" data-step-panel="2">
      <div class="ka-quiz__result" aria-live="polite" aria-atomic="true">
        <div class="ka-quiz__skeleton-wrap" role="status" aria-label="Loading your recommendation…">
          <div class="ka-skeleton"></div>
          <div class="ka-skeleton ka-skeleton--short"></div>
          <div class="ka-skeleton"></div>
          <div class="ka-skeleton ka-skeleton--shorter"></div>
        </div>
      </div>
      <button type="button" class="ka-quiz__reset-btn">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
        Start over
      </button>
    </div>

    {%- if product_benefits != blank -%}
      <div class="ka-benefits">
        <p class="ka-benefits__heading">Why it works</p>
        <ul class="ka-benefits__list">
          {%- for bullet in product_benefits -%}
            <li class="ka-benefits__item">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{- bullet | escape -}}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if block.settings.show_disclaimer -%}
      <p class="ka-quiz__disclaimer">
        These statements have not been evaluated by the Food and Drug Administration.
        This product is not intended to diagnose, treat, cure, or prevent any disease.
        Consult a qualified healthcare professional before use.
      </p>
    {%- endif -%}

  </div>
</div>

<script src="{{ 'routine-quiz.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "KA Routine Quiz",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Is this right for me?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Two quick questions to find your routine."
    },
    {
      "type": "text",
      "id": "api_endpoint",
      "label": "Recommendation API endpoint",
      "info": "Full URL of your /api/v1/recommendation POST endpoint."
    },
    {
      "type": "metaobject",
      "id": "quiz_config_ref",
      "label": "Quiz question set",
      "metaobject_type": "quiz_config",
      "info": "Select a quiz_config metaobject entry to customise questions and options."
    },
    {
      "type": "checkbox",
      "id": "show_disclaimer",
      "label": "Show FDA disclaimer",
      "default": true
    }
  ]
}
{% endschema %}
